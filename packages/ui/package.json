{
  "name": "@repo/ui",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI components for the Turborepo demo monorepo.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "echo \"No linter configured for @repo/ui\"",
    "play": "vite",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@repo/types": "*"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.11"
  }
}
