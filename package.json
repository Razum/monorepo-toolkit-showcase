{
  "name": "monorepo-toolkit-showcase",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:dry": "turbo run build --dry-run",
    "build:graph": "turbo run build --graph=turbo-graph.html",
    "build:summarize": "turbo run build --summarize",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "syncpack:format": "syncpack format",
    "syncpack:fix": "syncpack fix",
    "syncpack:lint": "syncpack lint",
    "syncpack:list": "syncpack list",
    "syncpack:update": "syncpack update --interactive",
    "syncpack:update:interactive": "syncpack update --interactive",
    "syncpack:update:check": "syncpack update --check"
  },
  "devDependencies": {
    "@repo/configs": "*",
    "oxfmt": "~0.50.0",
    "oxlint": "~1.65.0",
    "rimraf": "^6.0.1",
    "syncpack": "^15.1.2",
    "turbo": "^2.9.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "npm@9.8.1",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/configs"
  ]
}
