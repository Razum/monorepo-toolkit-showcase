{
  "name": "spa",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "clean": "rimraf dist",
    "dev": "vite",
    "lint": "NODE_OPTIONS=--experimental-strip-types oxlint . && NODE_OPTIONS=--experimental-strip-types oxfmt --check .",
    "lint:fix": "NODE_OPTIONS=--experimental-strip-types oxlint --fix . && NODE_OPTIONS=--experimental-strip-types oxfmt --write .",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@repo/toolkit": "*",
    "@repo/types": "*",
    "@repo/ui": "*",
    "axios": "^1.16.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@repo/configs": "*",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "rimraf": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
