{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**"
      ]
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "**/*.{ts,tsx}",
        "**/*.{mts,cts}",
        "!**/node_modules/**",
        "!**/dist/**",
        "!**/.next/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
